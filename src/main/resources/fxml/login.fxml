<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="missive.client.ui.LoginController"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="0" maxWidth="380">

        <VBox alignment="CENTER" spacing="2" styleClass="login-logo-block">
            <HBox alignment="CENTER" spacing="2">
                <Label text="missive" styleClass="logo-text"/>
                <Label text="_" styleClass="logo-accent"/>
            </HBox>
            <Label text="// secure messaging" styleClass="logo-sub"/>
        </VBox>

        <VBox spacing="14" styleClass="login-card">

            <VBox spacing="5">
                <Label text="USERNAME" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="your handle" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="PASSWORD" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="input-field"/>
            </VBox>

            <VBox spacing="8" style="-fx-padding: 6 0 0 0;">
                <Button fx:id="loginBtn" text="sign in" maxWidth="Infinity"
                        onAction="#handleLogin" styleClass="btn-primary"/>
                <Button fx:id="registerBtn" text="create account" maxWidth="Infinity"
                        onAction="#handleRegister" styleClass="btn-secondary"/>
            </VBox>

            <Label fx:id="statusLabel" text="" styleClass="status-label" wrapText="true"/>
        </VBox>

        <VBox alignment="CENTER" spacing="2" style="-fx-padding: 16 0 0 0;">
            <Label fx:id="serverLabel" text="server: ..." styleClass="version-label"/>
            <Label text="missive · v1.0" styleClass="version-label"/>
        </VBox>
    </VBox>
</StackPane>
